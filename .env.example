# Supabase (for likes, bookmarks, places & cities database)
# Create a project at: https://supabase.com
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
# Service role key — only needed for the seed-db script, never used in frontend
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# YouTube Data API Key
# Get yours at: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=your_youtube_api_key_here

# Rate limiting (optional, in milliseconds)
YOUTUBE_API_DELAY=100
TRANSCRIPT_FETCH_DELAY=500

# Google Custom Search API (for fetching food place images)
# Get yours at: https://console.cloud.google.com/apis/credentials
# Create a Custom Search Engine at: https://programmablesearchengine.google.com/
GOOGLE_SEARCH_API_KEY=your_google_search_api_key_here
GOOGLE_SEARCH_CX=your_custom_search_engine_id_here

# Google Maps Geocoding API (for accurate address coordinates)
# Get yours at: https://console.cloud.google.com/apis/credentials
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# OpenAI API Key (for summarizing transcripts into descriptions)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
